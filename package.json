{
  "name": "taiwan-brawl-back",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "node --test",
    "assets:generate": "node upload.js",
    "kv:upload": "wrangler kv bulk put assets.json --binding=STATIC_ASSETS --remote",
    "commit:suggest": "bash tool/suggest_commit_message.sh",
    "commit:suggest:front": "bash tool/suggest_commit_message.sh --repo ../taiwan_brawl_front"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "wrangler": "^4.62.0"
  }
}
